# ── إعدادات موقع نور القدس ──
# انسخ هذا الملف إلى .env.local (للتطوير) أو اضبط المتغيّرات في لوحة الاستضافة (Vercel).

# مصدر البيانات: mock (بيانات تجريبية للتطوير بدون ERP) أو erp (الـ API الحقيقي)
DATA_SOURCE=erp

# عنوان الـ PublicApi في نظام الـ ERP — لازم يشمل البادئة /api/v1/public
# مثال محلي: http://127.0.0.1:8001/api/v1/public
ERP_API_URL=https://erp.example.com/api/v1/public

# توكن الوصول (نفس PUBLIC_API_TOKEN المضبوط في الـ ERP). سرّي — سيرفر فقط، لا يُكشف للمتصفح.
ERP_API_TOKEN=

# مهلة نداء الـ API بالميلي ثانية (اختياري، الافتراضي 5000)
ERP_API_TIMEOUT_MS=5000

# عنوان الموقع النهائي (يُستخدم في canonical و sitemap و Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.nour-al-quds.example
